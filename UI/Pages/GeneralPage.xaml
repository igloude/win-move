<Page
    x:Class="Tactadile.UI.Pages.GeneralPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Padding="24" Spacing="0">
        <TextBlock Text="General" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,16" />

        <!-- Start with Windows -->
        <Grid Padding="0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Start with Windows" FontWeight="SemiBold" />
                <TextBlock Text="Automatically launch Tactadile when you sign in"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           FontSize="12" Margin="0,2,0,0" TextWrapping="Wrap" />
            </StackPanel>
            <ToggleSwitch x:Name="StartupToggle" Grid.Column="1"
                          VerticalAlignment="Center" MinWidth="0"
                          Toggled="OnStartupToggled" />
        </Grid>

        <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

        <!-- Edge snapping during move drag -->
        <Grid Padding="0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Edge snapping during move drag" FontWeight="SemiBold" />
                <TextBlock Text="Snap windows to screen edges and other windows while dragging"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           FontSize="12" Margin="0,2,0,0" TextWrapping="Wrap" />
            </StackPanel>
            <ToggleSwitch x:Name="EdgeSnapToggle" Grid.Column="1"
                          VerticalAlignment="Center" MinWidth="0"
                          Toggled="OnEdgeSnapToggled" />
        </Grid>

        <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

        <!-- Override Windows keybinds -->
        <Grid Padding="0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Override Windows keybinds" FontWeight="SemiBold" />
                <TextBlock Text="Replace default Windows keyboard shortcuts with Tactadile actions"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           FontSize="12" Margin="0,2,0,0" TextWrapping="Wrap" />
            </StackPanel>
            <ToggleSwitch x:Name="OverrideKeybindsToggle" Grid.Column="1"
                          VerticalAlignment="Center" MinWidth="0"
                          Toggled="OnOverrideKeybindsToggled" />
        </Grid>

        <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

        <!-- Disable Windows snap features -->
        <Grid Padding="0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Disable Windows snap features" FontWeight="SemiBold" />
                <TextBlock Text="Prevent Windows from snapping windows when dragged to edges"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           FontSize="12" Margin="0,2,0,0" TextWrapping="Wrap" />
            </StackPanel>
            <ToggleSwitch x:Name="DisableNativeSnapToggle" Grid.Column="1"
                          VerticalAlignment="Center" MinWidth="0"
                          Toggled="OnDisableNativeSnapToggled" />
        </Grid>

        <!-- Config section -->
        <TextBlock Text="Config"
                   Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,24,0,4" />

        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Open Config Folder" Click="OnOpenConfigFolder" />
            <Button Content="Reload Config" Click="OnReloadConfig" />
        </StackPanel>
    </StackPanel>
</Page>
